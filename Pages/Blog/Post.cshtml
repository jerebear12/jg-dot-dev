@page "{slug?}"
@model site.Pages.Blog.Post
@{
    ViewData["Title"] = "Post " + @Model.BlogPost?.Title;
}

<div class="max-w-xl mx-auto">
    <div class="mx-4">
        @if (Model.BlogPost is null)
        {
            <div>
                <p>No post found with that name.</p>
            </div>
        }
        else
        {
            <div>

            </div>
        }
    </div>
</div>

